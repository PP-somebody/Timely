# ============================================================
# 地震时间轴应用 — 环境变量配置
# ============================================================
# 复制此文件为 .env.local 并填入实际值
# cp .env.example .env.local
# ============================================================

# --- Supabase 数据库 ---
# 在 Supabase 项目 Settings > API 中获取
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# --- Vercel 部署（可选）---
# Vercel 自动注入，本地无需配置
# VERCEL_URL=your-app.vercel.app
